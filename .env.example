# ─── AI — server only; never NEXT_PUBLIC_*                                      
# Set AI_PROVIDER=openai to use OpenAI; defaults to openai when OPENAI_API_KEY is set
AI_PROVIDER=openai
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_SCORE_MODEL=gpt-4o-mini
# Claude (optional — used when AI_PROVIDER=anthropic or no OpenAI key)
# ANTHROPIC_API_KEY=
# ANTHROPIC_MODEL=
# ANTHROPIC_SCORE_MODEL=

# ─── Database (required in production)                                          
MONGODB_URI=

# ─── MongoDB pool (optional)                                                    
MONGODB_MAX_POOL_SIZE=10
MONGODB_MIN_POOL_SIZE=1
MONGODB_SERVER_SELECTION_MS=10000

# ─── Auth                                                                       
JWT_SECRET=

# ─── Job aggregation (server only)                                              
# Subscribe on RapidAPI: "LinkedIn Job Search API" (fantastic-jobs) — NOT linkedin-jobs-search
RAPIDAPI_KEY=
# Optional overrides (defaults: linkedin-job-search-api.p.rapidapi.com / active-jb-7d)
# RAPIDAPI_LINKEDIN_HOST=linkedin-job-search-api.p.rapidapi.com
# RAPIDAPI_LINKEDIN_ENDPOINT=active-jb-7d

# ─── Stripe (server secrets only)                                              
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_PRICE_SOLO=
STRIPE_PRICE_PRO=
STRIPE_PRICE_ENTERPRISE=

# ─── Stripe webhook raw payload max (express.raw)                              
STRIPE_WEBHOOK_BODY_LIMIT=1mb

# ─── HTTP API                                                                    
PORT=5000

# Browser CORS: comma-separated exact origins only (production).                
# Include all Vercel preview URLs if you open the dashboard there.               
# Wildcard subdomains supported, e.g. https://*.vercel.app                       
# Native mobile apps omit Origin → always allowed regardless of this list.     
CORS_ORIGINS=https://proposal-agent-app-web.vercel.app,https://*.vercel.app

# ─── Stripe redirect / portal return URLs — required in NODE_ENV=production       
APP_WEB_URL=https://your-app.vercel.app

# ─── Legacy fallbacks for local dev redirects (prefer APP_WEB_URL in prod)       
NEXT_PUBLIC_APP_URL=

# ─── Web (safe to expose)                                                        
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=

# ─── Limits                                                                       
JSON_BODY_LIMIT=1mb

# ─── Push notifications                                                          
FIREBASE_PROJECT_ID=

# ─── Transactional email (nodemailer) — onboarding sequence                     
# Use smtp.resend.com or smtp.gmail.com; leave unset to skip sends (safe no-op)  
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
FROM_EMAIL=
FROM_NAME=ProposalAgent
