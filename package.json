{
  "name": "proposalagent",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*",
    "server"
  ],
  "scripts": {
    "postinstall": "npm run build -w @proposalagent/shared && npm run build -w @proposalagent/api-client && npm run build -w @proposalagent/ui",
    "dev:web": "npm run dev --workspace=web",
    "dev:mobile": "npm run start --workspace=mobile",
    "dev:server": "npm run dev --workspace=server",
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "build:mobile:apk": "npm run build:android:apk --workspace=mobile"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
