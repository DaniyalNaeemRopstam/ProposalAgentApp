# Production — set in Vercel → Project → Settings → Environment Variables
# MUST be your Railway API host (serves /api/*). NEVER your *.vercel.app URL.
NEXT_PUBLIC_API_URL=https://proposalagentapp-production.up.railway.app
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_live_xxx

# Rare: only if Next image optimizer must load localhost API assets in tooling
# NEXT_PUBLIC_INCLUDE_LOCALHOST_IMAGES=
