# Copied to .env for local runs (not committed). EAS cloud builds: use EAS Secrets or eas.json profile env.
# Default (no .env): production Railway API below. For local API only, use http://localhost:5000
EXPO_PUBLIC_API_URL=https://proposalagentapp-production.up.railway.app

# Local API from Android emulator: localhost is rewritten to 10.0.2.2 automatically in __DEV__.
# Or set explicitly: EXPO_PUBLIC_API_URL=http://10.0.2.2:5000
